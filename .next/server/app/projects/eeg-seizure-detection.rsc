an",null,{"className":"font-mono text-sm text-[var(--muted)]","children":"// target metrics"}],["$","h2",null,{"className":"text-3xl font-heading font-bold text-[var(--fg)] mt-2","children":"Target Metrics"}],["$","div",null,{"className":"mt-8","children":["$","$L5",null,{"metrics":[{"label":"Target Accuracy","value":"~95%"},{"label":"Patients","value":"22"},{"label":"Feature Methods","value":"5"},{"label":"Status","value":"Active"}]}]}]]}]}],["$","section",null,{"id":"deep-dive","className":"py-24 space-y-16","children":[["$","$L3",null,{"children":[["$","span",null,{"className":"font-mono text-sm text-[var(--muted)]","children":"// deep-dive"}],["$","h2",null,{"className":"text-3xl font-heading font-bold text-[var(--fg)] mt-2","children":"Deep Dive"}]]}],["$","$L3",null,{"children":[["$","h3",null,{"className":"text-xl font-heading font-semibold text-[var(--fg)]","children":"Data Pipeline"}],["$","p",null,{"className":"text-[var(--muted)] mt-2","children":"Raw EDF files from the CHB-MIT dataset are parsed channel-by-channel, segmented into fixed-length windows (2s with 50% overlap), and labeled using seizure onset/offset annotations. Channels are standardized per-patient to handle amplitude variation."}],["$","div",null,{"className":"bg-[var(--card)] border border-[var(--card-border)] rounded-xl p-5 mt-4","children":["$","p",null,{"className":"font-mono text-sm text-[var(--fg)]","children":"EDF Files → Channel Extraction → 2s Windowing → Z-Score Normalization → Feature Extraction → Train/Val/Test Split"}]}]]}],["$","$L3",null,{"children":[["$","h3",null,{"className":"text-xl font-heading font-semibold text-[var(--fg)]","children":"Feature Engineering"}],["$","p",null,{"className":"text-[var(--muted)] mt-2","children":"Five complementary feature extraction methods capture different aspects of the EEG signal for classification."}],["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 gap-3 mt-4","children":[["$","div","Time-domain",{"className":"bg-[var(--ca